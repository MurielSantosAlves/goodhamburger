@page "/orders/edit/{Id:int}"
@attribute [Authorize]
@inject IMenuApiService MenuService
@inject IOrderApiService OrderService
@inject NavigationManager Navigation

<PageTitle>Editar Pedido - Good Hamburger</PageTitle>

<div class="container mt-4">
    <div class="mb-4">
        <h2>✏️ Editar Pedido #@Id</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/orders">Pedidos</a></li>
                <li class="breadcrumb-item active" aria-current="page">Editar #@Id</li>
            </ol>
        </nav>
    </div>
    
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @_errorMessage
            <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
        </div>
    }
    
    @if (_isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Carregando...</p>
        </div>
    }
    else if (_order == null)
    {
        <div class="alert alert-danger">Pedido não encontrado</div>
        <a href="/orders" class="btn btn-secondary">Voltar para Pedidos</a>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title mb-4">Cardápio</h5>
                        
                        @foreach (var group in _menuItems.GroupBy(m => m.Type))
                        {
                            <div class="mb-4">
                                <h6 class="text-uppercase text-muted mb-3">
                                    @(group.Key == MenuItemType.Sandwich ? "🍔 Sanduíches" : 
                                      group.Key == MenuItemType.SideDish ? "🍟 Acompanhamentos" : "🥤 Bebidas")
                                </h6>
                                
                                <div class="row g-2">
                                    @foreach (var item in group)
                                    {
                                        var isSelected = _selectedItems.Contains(item.Id);
                                        var canSelect = !isSelected && CanSelectItem(item.Type);
                                        
                                        <div class="col-md-6">
                                            <div class="card @(isSelected ? "border-primary" : "") @(!canSelect && !isSelected ? "opacity-50" : "")" 
                                                 style="cursor: @(canSelect || isSelected ? "pointer" : "not-allowed")"
                                                 @onclick="() => ToggleItem(item.Id, item.Type, canSelect || isSelected)">
                                                <div class="card-body p-3">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <div>
                                                            <h6 class="mb-1">@item.Name</h6>
                                                            <p class="mb-0 text-success fw-bold">@item.Price.ToString("C2")</p>
                                                        </div>
                                                        @if (isSelected)
                                                        {
                                                            <i class="bi bi-check-circle-fill text-primary fs-4"></i>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="card shadow-sm sticky-top" style="top: 20px;">
                    <div class="card-body">
                        <h5 class="card-title mb-4">Resumo do Pedido</h5>
                        
                        @if (!_selectedItems.Any())
                        {
                            <p class="text-muted">Selecione itens do cardápio</p>
                        }
                        else
                        {
                            <ul class="list-unstyled">
                                @foreach (var itemId in _selectedItems)
                                {
                                    var item = _menuItems.FirstOrDefault(m => m.Id == itemId);
                                    if (item != null)
                                    {
                                        <li class="mb-2">
                                            <div class="d-flex justify-content-between">
                                                <span>@item.Name</span>
                                                <span>@item.Price.ToString("C2")</span>
                                            </div>
                                        </li>
                                    }
                                }
                            </ul>
                            
                            <hr />
                            
                            <div class="mb-2">
                                <div class="d-flex justify-content-between">
                                    <span>Subtotal:</span>
                                    <span>@_subtotal.ToString("C2")</span>
                                </div>
                            </div>
                            
                            @if (_discountPercentage > 0)
                            {
                                <div class="mb-2 text-success">
                                    <div class="d-flex justify-content-between">
                                        <span>Desconto (@((_discountPercentage * 100).ToString("0"))%):</span>
                                        <span>-@_discountAmount.ToString("C2")</span>
                                    </div>
                                </div>
                            }
                            
                            <div class="mb-3">
                                <div class="d-flex justify-content-between fw-bold">
                                    <span>Total:</span>
                                    <span class="text-primary fs-5">@_total.ToString("C2")</span>
                                </div>
                            </div>
                            
                            <div class="d-grid gap-2">
                                <button class="btn btn-primary" @onclick="UpdateOrder" disabled="@_isSaving">
                                    @if (_isSaving)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                        <span>Salvando...</span>
                                    }
                                    else
                                    {
                                        <span>Salvar Alterações</span>
                                    }
                                </button>
                                <a href="/orders" class="btn btn-secondary">Cancelar</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }
    
    private OrderResponseDto? _order;
    private List<MenuItemDto> _menuItems = new();
    private HashSet<int> _selectedItems = new();
    private bool _isLoading = true;
    private bool _isSaving = false;
    private string? _errorMessage;
    
    private decimal _subtotal => _menuItems.Where(m => _selectedItems.Contains(m.Id)).Sum(m => m.Price);
    private decimal _discountPercentage => CalculateDiscountPercentage();
    private decimal _discountAmount => _subtotal * _discountPercentage;
    private decimal _total => _subtotal - _discountAmount;
    
    protected override async Task OnInitializedAsync()
    {
        _order = await OrderService.GetOrderByIdAsync(Id);
        _menuItems = await MenuService.GetMenuAsync();
        
        if (_order != null)
        {
            // Recuperar IDs dos itens do menu baseado nos nomes dos itens do pedido
            foreach (var orderItem in _order.Items)
            {
                var menuItem = _menuItems.FirstOrDefault(m => m.Name == orderItem.MenuItemName);
                if (menuItem != null)
                {
                    _selectedItems.Add(menuItem.Id);
                }
            }
        }
        
        _isLoading = false;
    }
    
    private bool CanSelectItem(MenuItemType type)
    {
        var selectedOfType = _menuItems.Where(m => _selectedItems.Contains(m.Id) && m.Type == type);
        return !selectedOfType.Any();
    }
    
    private void ToggleItem(int itemId, MenuItemType type, bool canToggle)
    {
        if (!canToggle)
            return;
            
        if (_selectedItems.Contains(itemId))
        {
            _selectedItems.Remove(itemId);
        }
        else if (CanSelectItem(type))
        {
            _selectedItems.Add(itemId);
        }
    }
    
    private decimal CalculateDiscountPercentage()
    {
        var hasSandwich = _menuItems.Any(m => _selectedItems.Contains(m.Id) && m.Type == MenuItemType.Sandwich);
        var hasSideDish = _menuItems.Any(m => _selectedItems.Contains(m.Id) && m.Type == MenuItemType.SideDish);
        var hasDrink = _menuItems.Any(m => _selectedItems.Contains(m.Id) && m.Type == MenuItemType.Drink);
        
        if (hasSandwich && hasSideDish && hasDrink)
            return 0.20m;
        if (hasSandwich && hasDrink)
            return 0.15m;
        if (hasSandwich && hasSideDish)
            return 0.10m;
            
        return 0m;
    }
    
    private async Task UpdateOrder()
    {
        if (!_selectedItems.Any())
        {
            _errorMessage = "Selecione pelo menos um item";
            return;
        }
        
        _isSaving = true;
        _errorMessage = null;
        
        try
        {
            var dto = new UpdateOrderDto(_selectedItems.ToList());
            var result = await OrderService.UpdateOrderAsync(Id, dto);
            
            if (result != null)
            {
                Navigation.NavigateTo("/orders");
            }
            else
            {
                _errorMessage = "Erro ao atualizar pedido. Tente novamente.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Erro ao atualizar pedido: {ex.Message}";
        }
        finally
        {
            _isSaving = false;
        }
    }
}
