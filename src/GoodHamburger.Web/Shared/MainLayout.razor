@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Good Hamburger</PageTitle>

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <h5 class="mb-0">🍔 Good Hamburger</h5>
            
            <AuthorizeView>
                <Authorized>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            @context.User.Identity?.Name
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><button class="dropdown-item" @onclick="Logout">Sair</button></li>
                        </ul>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div>
                        <a href="/login" class="btn btn-sm btn-primary">Entrar</a>
                        <a href="/register" class="btn btn-sm btn-outline-primary ms-2">Cadastrar</a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}
